#!/usr/bin/env python3
import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import tomllib
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
DEFAULT_DB_URL = "https://github.com/stefan-hoeck/idris2-pack-db.git"
BUILTIN_PACKAGES = {"base", "contrib", "linear", "network", "prelude", "test"}


def run(args, cwd=None, quiet=False):
    proc = subprocess.run(
        args,
        cwd=cwd,
        check=True,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if not quiet and proc.stderr:
        sys.stderr.write(proc.stderr)
    return proc.stdout.strip()


def clone_pack_db(target, url):
    run(["git", "clone", "--depth", "1", url, str(target)], quiet=True)


def parse_status(path):
    commits = {}
    rows = {}
    row_re = re.compile(
        r"^\| \[([^\]]+)\]\(([^)]+)\) \| ([^|]*) \| ([^|]*) \| "
        r"\[([0-9a-f]{7,40})\]\((?:[^)]*/commit/)?([0-9a-f]{40})\) \| ([^|]*) \|"
    )
    for line in path.read_text().splitlines():
        match = row_re.match(line)
        if not match:
            continue
        name, url, description, license_, _short, commit, tests = match.groups()
        commits[name] = commit
        rows[name] = {
            "url": url,
            "description": description.strip(),
            "license": license_.strip(),
            "commit": commit,
            "tests": tests.strip(),
        }
    return commits, rows


def resolve_ref(url, ref):
    if re.fullmatch(r"[0-9a-f]{40}", ref):
        return ref

    if ref.startswith("latest:"):
        ref = ref.split(":", 1)[1]

    candidates = [
        ref,
        f"refs/heads/{ref}",
        f"refs/tags/{ref}",
    ]
    output = run(["git", "ls-remote", url, *candidates], quiet=True)
    for line in output.splitlines():
        parts = line.split()
        if len(parts) == 2 and re.fullmatch(r"[0-9a-f]{40}", parts[0]):
            return parts[0]
    raise RuntimeError(f"could not resolve {ref!r} for {url}")


def materialize_source(cache_dir, url, rev):
    key = re.sub(r"[^A-Za-z0-9_.-]+", "_", f"{url}-{rev}")
    checkout = cache_dir / key
    if checkout.exists():
        return checkout

    checkout.mkdir(parents=True)
    run(["git", "init", "-q"], cwd=checkout, quiet=True)
    run(["git", "remote", "add", "origin", url], cwd=checkout, quiet=True)
    try:
        run(["git", "fetch", "--depth", "1", "origin", rev], cwd=checkout, quiet=True)
    except subprocess.CalledProcessError:
        run(["git", "fetch", "origin", rev], cwd=checkout, quiet=True)
    run(["git", "checkout", "-q", "FETCH_HEAD"], cwd=checkout, quiet=True)
    return checkout


def parse_ipkg(path):
    text = path.read_text(errors="replace")
    package = None
    version = None
    depends = []
    in_depends = False

    for raw_line in text.splitlines():
        line = raw_line.split("--", 1)[0].strip()
        if not line:
            in_depends = False
            continue

        package_match = re.match(r"package\s+(.+)$", line)
        if package_match:
            package = package_match.group(1).strip().strip('"')
            in_depends = False
            continue

        version_match = re.match(r"version\s*=\s*(.+)$", line)
        if version_match:
            version = version_match.group(1).strip().strip('"')
            in_depends = False
            continue

        depends_match = re.match(r"depends(?:\s*=\s*(.*))?$", line)
        if depends_match:
            dep_text = depends_match.group(1) or ""
            depends.extend(parse_dep_list(dep_text))
            in_depends = True
            continue

        if in_depends:
            if line.startswith(",") or line.startswith("="):
                depends.extend(parse_dep_list(line[1:]))
                continue
            if re.match(r"[A-Za-z][A-Za-z0-9_-]*\s*=", line):
                in_depends = False
            else:
                depends.extend(parse_dep_list(line))
                continue

        in_depends = False

    return {
        "packageName": package or path.stem,
        "version": version or "0.0.0",
        "deps": sorted(dep for dep in set(depends) if dep not in BUILTIN_PACKAGES),
    }


def parse_dep_list(text):
    deps = []
    for part in text.split(","):
        part = part.strip().strip('"')
        if not part:
            continue
        part = re.split(r"\s*(?:>=|<=|==|>|<)\s*", part, maxsplit=1)[0].strip()
        part = part.split()[0] if part.split() else ""
        if part:
            deps.append(part)
    return deps


def nix_string(value):
    return json.dumps(value)


def write_generated(specs, output):
    def write_deps(deps):
        if not deps:
            lines.append("    deps = [ ];")
        elif len(deps) == 1:
            lines.append(f"    deps = [ {nix_string(deps[0])} ];")
        else:
            lines.append("    deps = [")
            for dep in deps:
                lines.append(f"      {nix_string(dep)}")
            lines.append("    ];")

    lines = [
        "# Generated by scripts/update-pack-db. Do not edit by hand.",
        "{",
    ]
    for name in sorted(specs):
        spec = specs[name]
        lines.append(f"  {nix_string(name)} = {{")
        for key in ["packageName", "version", "url", "rev", "ipkg"]:
            lines.append(f"    {key} = {nix_string(spec[key])};")
        write_deps(spec["deps"])
        if spec.get("description"):
            lines.append(f"    description = {nix_string(spec['description'])};")
        if spec.get("license"):
            lines.append(f"    license = {nix_string(spec['license'])};")
        if spec.get("testStatus"):
            lines.append(f"    testStatus = {nix_string(spec['testStatus'])};")
        lines.append("  };")
    lines.append("}")
    output.parent.mkdir(parents=True, exist_ok=True)
    output.write_text("\n".join(lines) + "\n")


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--pack-db", type=Path)
    parser.add_argument("--pack-db-url", default=DEFAULT_DB_URL)
    parser.add_argument("--output", type=Path, default=ROOT / "generated" / "packages.nix")
    parser.add_argument("--cache", type=Path, default=ROOT / ".update-cache")
    args = parser.parse_args()

    args.cache.mkdir(parents=True, exist_ok=True)
    if args.pack_db:
        pack_db = args.pack_db
    else:
        pack_db = args.cache / "idris2-pack-db"
        if pack_db.exists():
            shutil.rmtree(pack_db)
        clone_pack_db(pack_db, args.pack_db_url)

    head = tomllib.loads((pack_db / "collections" / "HEAD.toml").read_text())
    status_commits, status_rows = parse_status(pack_db / "STATUS.md")

    source_cache = args.cache / "sources"
    source_cache.mkdir(exist_ok=True)

    specs = {}
    db = head["db"]
    for index, name in enumerate(sorted(db), start=1):
        entry = db[name]
        url = entry["url"]
        rev = status_commits.get(name)
        if rev is None:
            rev = resolve_ref(url, entry["commit"])
        ipkg = entry["ipkg"]

        print(f"[{index:03d}/{len(db):03d}] {name}", file=sys.stderr)
        source = materialize_source(source_cache, url, rev)
        ipkg_path = source / ipkg
        if not ipkg_path.exists():
            raise FileNotFoundError(f"{name}: missing {ipkg} in {url}@{rev}")

        parsed = parse_ipkg(ipkg_path)
        status = status_rows.get(name, {})
        specs[name] = {
            "packageName": parsed["packageName"],
            "version": parsed["version"],
            "url": url,
            "rev": rev,
            "ipkg": ipkg,
            "deps": parsed["deps"],
            "description": status.get("description", ""),
            "license": status.get("license", ""),
            "testStatus": status.get("tests", ""),
        }

    write_generated(specs, args.output)
    print(f"wrote {len(specs)} packages to {args.output}", file=sys.stderr)


if __name__ == "__main__":
    main()
